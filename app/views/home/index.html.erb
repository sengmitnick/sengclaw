<%# SengClaw 大胜龙虾 官网首页 — Dark Grid 全站统一风格 %>

<!-- ===== GLOBAL DARK WRAPPER ===== -->
<div style="background-color: #0a0a0a; min-height: 100vh;">

<!-- ===== NAVBAR ===== -->
<nav class="fixed top-0 left-0 right-0 z-50 border-b" style="background-color: rgba(10,10,10,0.92); border-color: rgba(245,158,11,0.12); backdrop-filter: blur(12px);">
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">
    <div class="flex items-center gap-2">
      <%= image_tag "sengclaw-logo.png", class: "w-9 h-9 object-contain", alt: "大胜龙虾" %>
      <span class="text-lg font-bold" style="color: #f5f5f5;">大胜龙虾</span>
      <span class="text-xs font-mono ml-1" style="color: rgba(245,158,11,0.6);">SengClaw</span>
    </div>
    <div class="hidden md:flex items-center gap-8">
      <a href="#features" class="text-sm transition-colors" style="color: rgba(255,255,255,0.55);" onmouseover="this.style.color='#F59E0B'" onmouseout="this.style.color='rgba(255,255,255,0.55)'">功能特性</a>
      <a href="#how-it-works" class="text-sm transition-colors" style="color: rgba(255,255,255,0.55);" onmouseover="this.style.color='#F59E0B'" onmouseout="this.style.color='rgba(255,255,255,0.55)'">使用步骤</a>
      <a href="#about" class="text-sm transition-colors" style="color: rgba(255,255,255,0.55);" onmouseover="this.style.color='#F59E0B'" onmouseout="this.style.color='rgba(255,255,255,0.55)'">关于大胜</a>
      <a href="#contact" class="text-sm transition-colors" style="color: rgba(255,255,255,0.55);" onmouseover="this.style.color='#F59E0B'" onmouseout="this.style.color='rgba(255,255,255,0.55)'">联系我们</a>
    </div>
    <a href="#contact" class="text-sm font-semibold px-5 py-2 transition-all" style="background-color: #F59E0B; color: #0a0a0a;">加入交流群</a>
  </div>
</nav>

<!-- ===== HERO ===== -->
<section class="relative pt-40 pb-28 px-6" style="background-image: linear-gradient(rgba(245,158,11,0.07) 1px, transparent 1px), linear-gradient(90deg, rgba(245,158,11,0.07) 1px, transparent 1px); background-size: 48px 48px;">
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 70% 60% at 50% 40%, rgba(245,158,11,0.06) 0%, transparent 70%);"></div>
  <div class="max-w-4xl mx-auto text-center relative">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-8 text-xs font-mono" style="background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.25); color: #F59E0B;">
      <%= lucide_icon "zap", class: "w-3 h-3" %>
      AI Skill 工具 · 独立开发者出品
    </div>
    <h1 class="font-extrabold leading-tight mb-6" style="font-size: clamp(2.8rem, 6vw, 4.2rem); color: #f5f5f5;">
      让每一位创作者拥有<br><span style="color: #F59E0B;">7×24 AI 助手</span>
    </h1>
    <p class="text-lg max-w-xl mx-auto mb-12 leading-relaxed" style="color: rgba(255,255,255,0.5);">
      精选真实业务场景打磨的 AI Skill，开箱即用。<br>也教你怎么做——未来一起共建 Skill 生态。
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#contact" class="inline-flex items-center justify-center gap-2 font-semibold px-8 py-3 text-sm transition-all" style="background-color: #F59E0B; color: #0a0a0a;">
        <%= lucide_icon "message-circle", class: "w-4 h-4" %>
        加入交流群
      </a>
      <a href="#how-it-works" class="inline-flex items-center justify-center gap-2 font-semibold px-8 py-3 text-sm transition-all" style="border: 1px solid rgba(245,158,11,0.4); color: rgba(255,255,255,0.8);" onmouseover="this.style.borderColor='rgba(245,158,11,0.8)';this.style.color='#F59E0B'" onmouseout="this.style.borderColor='rgba(245,158,11,0.4)';this.style.color='rgba(255,255,255,0.8)'">
        查看使用步骤
      </a>
    </div>
    <div class="mt-16 flex justify-center">
      <div class="flex flex-col items-center gap-2" style="opacity: 0.35;">
        <span class="text-xs" style="color: rgba(255,255,255,0.5);">向下滚动</span>
        <%= lucide_icon "chevron-down", class: "w-4 h-4 animate-bounce", style: "color: rgba(255,255,255,0.5)" %>
      </div>
    </div>
  </div>
</section>

<!-- ===== FEATURES ===== -->
<section id="features" class="py-20 px-6 border-t" style="border-color: rgba(245,158,11,0.08);">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-xs font-mono mb-3" style="color: #F59E0B; letter-spacing: 0.1em;">WHY SENGCLAW</p>
      <h2 class="text-3xl font-bold mb-3" style="color: #f5f5f5;">3 点选择大胜龙虾的理由</h2>
      <p style="color: rgba(255,255,255,0.45); font-size: 0.95rem;">真实场景打磨，拿来就用</p>
    </div>
    <div class="grid md:grid-cols-3 gap-px" style="background-color: rgba(245,158,11,0.08);">
      <div class="p-8" style="background-color: #0f0f0f;">
        <div class="w-10 h-10 flex items-center justify-center mb-5" style="background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.2);">
          <%= lucide_icon "package", class: "w-5 h-5", style: "color: #F59E0B;" %>
        </div>
        <h3 class="text-base font-bold mb-2" style="color: #f5f5f5;">节省 90% 的时间</h3>
        <p class="text-xs font-medium mb-3" style="color: rgba(245,158,11,0.7);">省下一个助理的成本</p>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">写文章、做选题、整理纪要、审合同——过去需要反复调 AI 的活，Skill 全包。大胜亲自打磨，开箱即用。</p>
      </div>
      <div class="p-8" style="background-color: #0f0f0f;">
        <div class="w-10 h-10 flex items-center justify-center mb-5" style="background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.2);">
          <%= lucide_icon "trending-up", class: "w-5 h-5", style: "color: #F59E0B;" %>
        </div>
        <h3 class="text-base font-bold mb-2" style="color: #f5f5f5;">越用越懂你</h3>
        <p class="text-xs font-medium mb-3" style="color: rgba(245,158,11,0.7);">长期记忆积累沉淀</p>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">和 AI 聊的内容本地沉淀，不从零开始。偏好、风格、经验库，随使用不断积累，变成你的专属知识库。</p>
      </div>
      <div class="p-8" style="background-color: #0f0f0f;">
        <div class="w-10 h-10 flex items-center justify-center mb-5" style="background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.2);">
          <%= lucide_icon "message-square", class: "w-5 h-5", style: "color: #F59E0B;" %>
        </div>
        <h3 class="text-base font-bold mb-2" style="color: #f5f5f5;">飞书 / 企微直接用</h3>
        <p class="text-xs font-medium mb-3" style="color: rgba(245,158,11,0.7);">不用切换软件</p>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">在飞书或企微发一条消息就能调用 Skill，或设置定时自动运转。你的工具，住在你的工作平台里。</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== HOW IT WORKS ===== -->
<section id="how-it-works" class="py-20 px-6 border-t" style="background-color: #080808; border-color: rgba(245,158,11,0.08);">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-xs font-mono mb-3" style="color: #F59E0B; letter-spacing: 0.1em;">HOW IT WORKS</p>
      <h2 class="text-3xl font-bold mb-3" style="color: #f5f5f5;">三步用上你的第一个 Skill</h2>
      <p style="color: rgba(255,255,255,0.45); font-size: 0.95rem;">不用配置，不用写提示词，拿来直接用</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="flex flex-col items-center text-center">
        <div class="w-12 h-12 flex items-center justify-center mb-5 text-lg font-bold" style="background-color: #F59E0B; color: #0a0a0a;">1</div>
        <h3 class="text-base font-bold mb-2" style="color: #f5f5f5;">浏览精选 Skill 合集</h3>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">大胜从真实业务场景打磨的 Skill——写文章、做选题、整理纪要、审合同。找到你需要的，直接用。</p>
      </div>
      <div class="flex flex-col items-center text-center">
        <div class="w-12 h-12 flex items-center justify-center mb-5 text-lg font-bold" style="background-color: #F59E0B; color: #0a0a0a;">2</div>
        <h3 class="text-base font-bold mb-2" style="color: #f5f5f5;">一句话触发，自动执行</h3>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">在飞书 / 企微发一条消息就能调用，或设置定时自动运转。越用越顺手，越用越懂你。</p>
      </div>
      <div class="flex flex-col items-center text-center">
        <div class="w-12 h-12 flex items-center justify-center mb-5 text-lg font-bold" style="background-color: #F59E0B; color: #0a0a0a;">3</div>
        <h3 class="text-base font-bold mb-2" style="color: #f5f5f5;">学会了，做自己的 Skill</h3>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">小红书和知识星球教你怎么把自己的业务沉淀成 Skill。学会后，你也能做出只属于你的 AI 工作流。</p>
      </div>
    </div>

    <!-- 路线图 -->
    <div class="mt-14 p-8 border" style="border-color: rgba(245,158,11,0.15); background-color: #0f0f0f;">
      <p class="text-xs font-mono text-center mb-2" style="color: #F59E0B; letter-spacing: 0.1em;">ROADMAP</p>
      <h3 class="text-xl font-bold text-center mb-8" style="color: #f5f5f5;">大胜龙虾正在成长</h3>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="flex flex-col items-center gap-3">
          <div class="w-10 h-10 flex items-center justify-center" style="background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2);">
            <%= lucide_icon "check", class: "w-5 h-5", style: "color: #22c55e;" %>
          </div>
          <p class="font-semibold text-sm" style="color: #f5f5f5;">精选 Skill 上架</p>
          <p class="text-xs text-center" style="color: rgba(255,255,255,0.35);">大胜亲自打磨，开箱即用</p>
          <span class="text-xs px-3 py-1 font-mono" style="background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2); color: #22c55e;">已上线</span>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-10 h-10 flex items-center justify-center" style="background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.2);">
            <%= lucide_icon "book-open", class: "w-5 h-5", style: "color: #F59E0B;" %>
          </div>
          <p class="font-semibold text-sm" style="color: #f5f5f5;">Skill 制作课程</p>
          <p class="text-xs text-center" style="color: rgba(255,255,255,0.35);">小红书演示 + 知识星球教学</p>
          <span class="text-xs px-3 py-1 font-mono" style="background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.2); color: #F59E0B;">进行中</span>
        </div>
        <div class="flex flex-col items-center gap-3">
          <div class="w-10 h-10 flex items-center justify-center" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);">
            <%= lucide_icon "store", class: "w-5 h-5", style: "color: rgba(255,255,255,0.3);" %>
          </div>
          <p class="font-semibold text-sm" style="color: #f5f5f5;">Skill 共创市场</p>
          <p class="text-xs text-center" style="color: rgba(255,255,255,0.35);">用户发布自己的 Skill，一起共建</p>
          <span class="text-xs px-3 py-1 font-mono" style="border: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.3);">即将上线</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== TESTIMONIALS ===== -->
<section id="testimonials" class="py-20 px-6 border-t" style="border-color: rgba(245,158,11,0.08);">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-xs font-mono mb-3" style="color: #F59E0B; letter-spacing: 0.1em;">TESTIMONIALS</p>
      <h2 class="text-3xl font-bold mb-3" style="color: #f5f5f5;">他们的 Skill 已经在跑了</h2>
      <p style="color: rgba(255,255,255,0.45); font-size: 0.95rem;">真实使用场景，不是编的</p>
    </div>
    <div class="grid md:grid-cols-3 gap-px" style="background-color: rgba(245,158,11,0.08);">
      <div class="p-6" style="background-color: #0f0f0f;">
        <div class="flex gap-1 mb-4">
          <% 5.times do %><%= lucide_icon "star", class: "w-3.5 h-3.5 fill-current", style: "color: #F59E0B;" %><% end %>
        </div>
        <p class="text-sm leading-relaxed mb-5" style="color: rgba(255,255,255,0.55);">"我做小红书，以前想一个标题要想半天。现在 Skill 帮我，一句话出 27 个标题，每次都很对味。"</p>
        <div class="flex items-center gap-3 pt-4 border-t" style="border-color: rgba(255,255,255,0.08);">
          <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=40&h=40&fit=crop&crop=face" class="w-8 h-8 object-cover" alt="小林">
          <div>
            <p class="text-sm font-semibold" style="color: #f5f5f5;">小林</p>
            <p class="text-xs" style="color: rgba(255,255,255,0.35);">小红书内容创作者</p>
          </div>
        </div>
      </div>
      <div class="p-6" style="background-color: #0f0f0f;">
        <div class="flex gap-1 mb-4">
          <% 5.times do %><%= lucide_icon "star", class: "w-3.5 h-3.5 fill-current", style: "color: #F59E0B;" %><% end %>
        </div>
        <p class="text-sm leading-relaxed mb-5" style="color: rgba(255,255,255,0.55);">"每天早上 8 点，行业晨报 Skill 自动跑完发到飞书，我到公司直接看。比自己整理快了 10 倍。"</p>
        <div class="flex items-center gap-3 pt-4 border-t" style="border-color: rgba(255,255,255,0.08);">
          <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=40&h=40&fit=crop&crop=face" class="w-8 h-8 object-cover" alt="阿杰">
          <div>
            <p class="text-sm font-semibold" style="color: #f5f5f5;">阿杰</p>
            <p class="text-xs" style="color: rgba(255,255,255,0.35);">互联网运营</p>
          </div>
        </div>
      </div>
      <div class="p-6" style="background-color: #0f0f0f;">
        <div class="flex gap-1 mb-4">
          <% 5.times do %><%= lucide_icon "star", class: "w-3.5 h-3.5 fill-current", style: "color: #F59E0B;" %><% end %>
        </div>
        <p class="text-sm leading-relaxed mb-5" style="color: rgba(255,255,255,0.55);">"我一个人接了以前三人才能跑的项目。合同审查 Skill 帮我省了大量时间，客户都说我响应很快。"</p>
        <div class="flex items-center gap-3 pt-4 border-t" style="border-color: rgba(255,255,255,0.08);">
          <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=40&h=40&fit=crop&crop=face" class="w-8 h-8 object-cover" alt="老陈">
          <div>
            <p class="text-sm font-semibold" style="color: #f5f5f5;">老陈</p>
            <p class="text-xs" style="color: rgba(255,255,255,0.35);">独立创业者 · 一人公司</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== ABOUT ===== -->
<section id="about" class="py-20 px-6 border-t" style="background-color: #080808; border-color: rgba(245,158,11,0.08);">
  <div class="max-w-4xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div class="flex flex-col items-center md:items-start gap-6">
        <%= image_tag "avatar.jpg", class: "w-28 h-28 object-cover", style: "border: 1px solid rgba(245,158,11,0.2);", alt: "张润胜" %>
        <div>
          <p class="text-xl font-bold mb-1" style="color: #f5f5f5;">张润胜</p>
          <p class="text-sm mb-1" style="color: rgba(255,255,255,0.55);">🦞 SengClaw 创始人 ⚡️ AI 产品人 × AI 眼镜，边折腾边记录</p>
          <p class="text-xs mb-4" style="color: rgba(255,255,255,0.3);">小红书 @soloverse · 广东 · 1千+ 获赞收藏</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-3 py-1 font-mono" style="border: 1px solid rgba(245,158,11,0.2); color: rgba(245,158,11,0.7);">SengClaw 创始人</span>
            <span class="text-xs px-3 py-1 font-mono" style="border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.35);">AI 产品人</span>
            <span class="text-xs px-3 py-1 font-mono" style="border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.35);">AI 眼镜探索者</span>
            <span class="text-xs px-3 py-1 font-mono" style="border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.35);">独立开发者</span>
          </div>
        </div>
      </div>
      <div class="space-y-5">
        <p class="text-xs font-mono mb-2" style="color: #F59E0B; letter-spacing: 0.1em;">ABOUT</p>
        <h2 class="text-3xl font-bold" style="color: #f5f5f5;">为什么做大胜龙虾？</h2>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">
          我是前端开发者出身。AI 时代来了以后，我开始焦虑——写代码这件事，AI 越来越能代替。于是我开始探索：<strong style="color: rgba(255,255,255,0.8);">怎么用 AI 重建自己的工作方式？</strong>
        </p>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">
          我把自己每个真实的业务场景——写文章、做选题、审合同、整理纪要——一个一个沉淀成 Skill。用着用着发现，<strong style="color: rgba(255,255,255,0.8);">这些工具比雇人还好使。</strong>
        </p>
        <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">
          大胜龙虾就是这些 Skill 的家。我先把自己的上架，再在小红书和知识星球教你怎么做。<strong style="color: rgba(255,255,255,0.8);">最终，你做的 Skill 也可以上架，我们一起把这个工具库越建越大。</strong>
        </p>
        <div class="flex items-center gap-4 pt-2">
          <a href="https://www.xiaohongshu.com/user/profile/588c948b5e87e71a5e9b160e" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm transition-colors" style="color: #F59E0B;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
            <%= lucide_icon "external-link", class: "w-4 h-4" %>
            小红书 @soloverse
          </a>
          <a href="#contact" class="flex items-center gap-2 text-sm transition-colors" style="color: rgba(255,255,255,0.4);" onmouseover="this.style.color='#F59E0B'" onmouseout="this.style.color='rgba(255,255,255,0.4)'">
            <%= lucide_icon "message-circle", class: "w-4 h-4" %>
            加我微信
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== CTA / CONTACT ===== -->
<section id="contact" class="py-20 px-6 border-t" style="border-color: rgba(245,158,11,0.08);">
  <div class="max-w-3xl mx-auto text-center">
