<!-- Navigation -->
<nav class="fixed top-0 left-0 right-0 z-50 bg-surface/95 backdrop-blur border-b border-border">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-16">
    <div class="flex items-center gap-3">
      <%= image_tag "sengclaw-logo.png", class: "w-8 h-8 object-contain", alt: "大胜龙虾" %>
      <span class="text-xl font-bold text-primary">大胜龙虾</span>
      <span class="text-xs text-muted font-medium hidden sm:block">SengClaw</span>
    </div>
    <div class="hidden md:flex items-center gap-8">
      <a href="#features" class="text-sm font-medium text-secondary hover:text-primary transition-colors">功能特性</a>
      <a href="#how-it-works" class="text-sm font-medium text-secondary hover:text-primary transition-colors">工作原理</a>
      <a href="#pricing" class="text-sm font-medium text-secondary hover:text-primary transition-colors">定价方案</a>
      <a href="#about" class="text-sm font-medium text-secondary hover:text-primary transition-colors">关于我们</a>
    </div>
    <div class="flex items-center gap-3">
      <a href="https://sengclaw.com" class="btn-ghost btn-sm hidden md:inline-flex">登录</a>
      <a href="#contact" class="btn-primary btn-sm">免费体验</a>
    </div>
  </div>
</nav>

<!-- Hero Section -->
<section class="pt-32 pb-24 px-6 relative overflow-hidden">
  <div class="absolute inset-0 -z-10" style="background: radial-gradient(ellipse 80% 60% at 50% -10%, hsl(210 90% 45% / 0.12), transparent 70%)"></div>
  <div class="max-w-5xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-border bg-surface-elevated text-sm text-secondary mb-8">
      <%= lucide_icon "zap", class: "w-4 h-4 text-primary" %>
      <span>AI 时代的研发新范式 · 一人公司的超级武器</span>
    </div>
    <h1 class="text-5xl md:text-7xl font-extrabold leading-tight mb-6">
      <span class="text-foreground">属于你的 </span><span class="text-primary">AI 研发团队</span>
    </h1>
    <p class="text-xl text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
      随时在线，自主运转，<br>
      像有一支研发团队在背后支撑你。
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#contact" class="btn-primary btn-lg">
        <%= lucide_icon "rocket", class: "w-5 h-5" %>
        开始转型
      </a>
      <a href="#how-it-works" class="btn-outline btn-lg">
        <%= lucide_icon "play-circle", class: "w-5 h-5" %>
        了解工作原理
      </a>
    </div>
    <p class="text-sm text-muted mt-6">已有 <strong class="text-foreground">200+</strong> 创业者和团队正在转型</p>
  </div>

  <!-- Hero Visual -->
  <div class="max-w-4xl mx-auto mt-16">
    <div class="card-elevated rounded-2xl overflow-hidden shadow-xl border border-border">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-border bg-surface-elevated">
        <div class="w-3 h-3 rounded-full bg-danger"></div>
        <div class="w-3 h-3 rounded-full bg-warning"></div>
        <div class="w-3 h-3 rounded-full bg-success"></div>
        <span class="text-xs text-muted ml-2 font-mono">sengclaw ~ AI 工作台</span>
      </div>
      <div class="p-6 font-mono text-sm bg-surface space-y-3">
        <div class="flex gap-3">
          <span class="text-muted text-xs shrink-0 pt-0.5">// 传统软件时代</span>
        </div>
        <div class="flex gap-3">
          <span class="text-muted line-through text-xs">软件 → 设计给人操作 → 人看界面 → 人点按钮 → 人输入数据</span>
        </div>
        <div class="flex gap-3 mt-4">
          <span class="text-primary text-xs shrink-0 pt-0.5">// 新一代软件时代</span>
        </div>
        <div class="flex gap-3">
          <span class="text-foreground font-bold shrink-0 flex items-center gap-1"><%= image_tag "sengclaw-logo.png", class: "w-4 h-4 object-contain inline" %> AI:</span>
          <span class="text-foreground">我需要查询今天的销售数据并生成报告</span>
        </div>
        <div class="flex gap-3 pl-12">
          <span class="text-success text-xs">✓ 调用数据 API → 分析汇总 → 自动生成报告</span>
        </div>
        <div class="flex gap-3">
          <span class="text-secondary font-bold shrink-0 flex items-center gap-1"><%= image_tag "sengclaw-logo.png", class: "w-4 h-4 object-contain inline" %> AI:</span>
          <span class="text-secondary">发现库存异常，已自动触发补货流程 ✅</span>
        </div>
        <div class="flex gap-3 mt-2">
          <span class="text-muted text-xs">→ 没有人工干预，没有界面点击，软件面向 AI 运行</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Social Proof -->
<section class="py-12 border-y border-border bg-surface-elevated">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <p class="text-sm text-muted mb-8 uppercase tracking-widest">正在转型的人群</p>
    <div class="flex flex-wrap justify-center gap-8 text-secondary">
      <span class="flex items-center gap-2 text-sm font-medium">
        <%= lucide_icon "user", class: "w-4 h-4 text-primary" %> 想用 AI 开公司的个人
      </span>
      <span class="flex items-center gap-2 text-sm font-medium">
        <%= lucide_icon "briefcase", class: "w-4 h-4 text-primary" %> 创业者 / 一人公司
      </span>
      <span class="flex items-center gap-2 text-sm font-medium">
        <%= lucide_icon "users", class: "w-4 h-4 text-primary" %> 企业研发团队
      </span>
      <span class="flex items-center gap-2 text-sm font-medium">
        <%= lucide_icon "building", class: "w-4 h-4 text-primary" %> 传统软件公司
      </span>
      <span class="flex items-center gap-2 text-sm font-medium">
        <%= lucide_icon "zap", class: "w-4 h-4 text-primary" %> 想弯道超车的团队
      </span>
    </div>
  </div>
</section>

<!-- Features Section -->
<section id="features" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-foreground mb-4">大胜龙虾帮你做什么？</h2>
      <p class="text-lg text-secondary max-w-2xl mx-auto">不是又一个 AI 写代码工具——而是帮你率先完成软件范式转型的基建平台</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">

      <!-- Feature 1 -->
      <div class="card p-6 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-4">
          <%= lucide_icon "cpu", class: "w-6 h-6 text-primary" %>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">面向 AI 的软件基建</h3>
        <p class="text-secondary text-sm leading-relaxed">帮你把现有业务流程改造成 AI 可直接调用的结构——不是加个聊天框，而是让 AI 真正成为你系统的驱动者。</p>
      </div>

      <!-- Feature 2 -->
      <div class="card p-6 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center mb-4">
          <%= lucide_icon "git-branch", class: "w-6 h-6 text-secondary" %>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">AI 协同开发体系</h3>
        <p class="text-secondary text-sm leading-relaxed">不只是工具，而是一套方法论 + 交付体系。帮你的团队从"人写代码"进化到"人 + AI 协同"的新开发模式。</p>
      </div>

      <!-- Feature 3 -->
      <div class="card p-6 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-success/10 flex items-center justify-center mb-4">
          <%= lucide_icon "user-check", class: "w-6 h-6 text-success" %>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">一人公司的超级武器</h3>
        <p class="text-secondary text-sm leading-relaxed">一个人，借助 AI 驱动的新型软件体系，能做以前一个团队才能做的事。这才是 AI 时代真正的个人杠杆。</p>
      </div>

      <!-- Feature 4 -->
      <div class="card p-6 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-info/10 flex items-center justify-center mb-4">
          <%= lucide_icon "layers", class: "w-6 h-6 text-info" %>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">技能包 = AI 时代的应用</h3>
        <p class="text-secondary text-sm leading-relaxed">传统软件面向人设计界面；技能包面向 AI 设计协议。我们帮你构建和部署下一代形态的软件产品。</p>
      </div>

      <!-- Feature 5 -->
      <div class="card p-6 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-warning/10 flex items-center justify-center mb-4">
          <%= lucide_icon "clock", class: "w-6 h-6 text-warning" %>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">自主运行 · 无需人工干预</h3>
        <p class="text-secondary text-sm leading-relaxed">AI 自动完成数据分析、流程触发、报告生成。软件不再等人操作，而是主动驱动业务运转。</p>
      </div>

      <!-- Feature 6 -->
      <div class="card p-6 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 rounded-xl bg-danger/10 flex items-center justify-center mb-4">
          <%= lucide_icon "shield-check", class: "w-6 h-6 text-danger" %>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">本地部署 · 数据主权在你</h3>
        <p class="text-secondary text-sm leading-relaxed">整套体系跑在你本地或私有服务器，数据不出境，企业级安全标准，适合对数据敏感的团队和企业。</p>
      </div>

    </div>
  </div>
</section>

<!-- How it works -->
<section id="how-it-works" class="py-24 px-6 bg-surface-elevated">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-foreground mb-4">转型三步走</h2>
      <p class="text-secondary text-lg">从传统软件思维，到面向 AI 的新范式</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-16 h-16 rounded-2xl bg-primary flex items-center justify-center mx-auto mb-4 text-2xl font-black shadow-md" style="color: hsl(0 0% 100%)">1</div>
        <h3 class="text-lg font-semibold text-foreground mb-2">诊断现有业务</h3>
        <p class="text-secondary text-sm">梳理你当前的业务流程和系统，找出哪些环节可以被 AI 直接接管、替代人工操作。</p>
      </div>
      <div class="text-center">
        <div class="w-16 h-16 rounded-2xl bg-primary flex items-center justify-center mx-auto mb-4 text-2xl font-black shadow-md" style="color: hsl(0 0% 100%)">2</div>
        <h3 class="text-lg font-semibold text-foreground mb-2">构建 AI 原生体系</h3>
        <p class="text-secondary text-sm">用大胜龙虾部署面向 AI 的软件基建，让 AI 能直接调用你的系统，而不是模拟人点界面。</p>
      </div>
      <div class="text-center">
        <div class="w-16 h-16 rounded-2xl bg-primary flex items-center justify-center mx-auto mb-4 text-2xl font-black shadow-md" style="color: hsl(0 0% 100%)">3</div>
        <h3 class="text-lg font-semibold text-foreground mb-2">AI 驱动，持续进化</h3>
        <p class="text-secondary text-sm">系统上线后 AI 自主运转，人负责决策和方向，效率比传统团队高出数倍，成本大幅降低。</p>
      </div>
    </div>
  </div>
</section>

