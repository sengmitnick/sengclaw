            <p class="text-xs text-muted">研发团队负责人</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Pricing -->
<section id="pricing" class="py-24 px-6 bg-surface-elevated">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <h2 class="text-4xl font-bold text-foreground mb-4">定价</h2>
      <p class="text-secondary text-lg max-w-xl mx-auto">如果你在考虑成本，可以先不考虑大胜龙虾。<br>我们只服务想认真用 AI 的人。</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">

      <!-- OPC / 小团队 -->
      <div class="card p-8 border-2 border-primary relative">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="badge-primary text-xs px-3 py-1">一人公司 · 小团队</span>
        </div>
        <h3 class="text-xl font-bold text-foreground mb-1 mt-2">按席位订阅</h3>
        <p class="text-sm text-muted mb-6">适合创业者、独立开发者、小型团队</p>
        <div class="flex items-end gap-1 mb-1">
          <span class="text-5xl font-extrabold text-foreground">¥2,999</span>
          <span class="text-base text-muted mb-2">/席位/年</span>
        </div>
        <p class="text-xs text-muted mb-8">不到一位兼职员工两天的成本，却能替你干一个团队的活</p>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            AI 工作台 · 随时在线自主运转
          </li>
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            飞书 / 企微 接入
          </li>
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            长期记忆 + 定时任务
          </li>
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            自定义技能包（Skill）
          </li>
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            线上课程 + 定期答疑
          </li>
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            席位可按需叠加
          </li>
        </ul>
        <a href="#contact" class="btn-primary w-full text-center">扫码咨询 · 开始部署</a>
      </div>

      <!-- 传统企业 -->
      <div class="card p-8">
        <h3 class="text-xl font-bold text-foreground mb-1 mt-2">企业定制部署</h3>
        <p class="text-sm text-muted mb-6">适合传统企业、有私有化需求的团队</p>
        <div class="flex items-end gap-1 mb-1">
          <span class="text-3xl font-extrabold text-foreground">定制报价</span>
        </div>
        <p class="text-xs text-muted mb-8">首次部署费 + 年度软件服务费，根据规模和需求定制</p>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            业务流程深度诊断
          </li>
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            私有化部署 · 数据不出企业
          </li>
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            与现有系统集成（ERP/CRM…）
          </li>
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            专属技能包定制开发
          </li>
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            专属技术顾问长期跟进
          </li>
          <li class="flex items-center gap-2 text-sm text-secondary">
            <%= lucide_icon "check", class: "w-4 h-4 text-success shrink-0" %>
            年度软件维护 · 持续迭代
          </li>
        </ul>
        <a href="#contact" class="btn-outline w-full text-center">联系洽谈 · 获取方案</a>
      </div>

    </div>

    <!-- 底部说明 -->
    <p class="text-center text-sm text-muted mt-10">
      不确定适合哪种？先扫码聊聊，我们帮你判断。
    </p>

  </div>
</section>

<!-- CTA / Contact -->
<section id="contact" class="py-24 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <div class="w-20 h-20 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-6">
      <%= image_tag "sengclaw-logo.png", class: "w-14 h-14 object-contain", alt: "大胜龙虾" %>
    </div>
    <h2 class="text-4xl font-bold text-foreground mb-4">准备好开始了？</h2>
    <p class="text-lg text-secondary mb-3">扫码加我微信，我们直接聊</p>
    <p class="text-sm text-muted mb-10">无论你是一人公司还是传统企业，先聊需求，再谈方案</p>

    <div class="flex flex-col items-center gap-6">
      <!-- QR Code -->
      <div class="rounded-xl overflow-hidden">
        <%= image_tag "contact-qrcode.png", class: "w-80 h-auto block", alt: "微信扫码联系" %>
      </div>

      <!-- Tips -->
      <div class="grid sm:grid-cols-3 gap-4 w-full max-w-xl text-sm">
        <div class="card p-4 text-center">
          <%= lucide_icon "message-circle", class: "w-5 h-5 text-primary mx-auto mb-1" %>
          <p class="text-foreground font-medium">免费咨询</p>
          <p class="text-muted text-xs mt-1">先聊需求再说方案</p>
        </div>
        <div class="card p-4 text-center">
          <%= lucide_icon "clock", class: "w-5 h-5 text-primary mx-auto mb-1" %>
          <p class="text-foreground font-medium">快速响应</p>
          <p class="text-muted text-xs mt-1">工作时间内实时回复</p>
        </div>
        <div class="card p-4 text-center">
          <%= lucide_icon "shield-check", class: "w-5 h-5 text-primary mx-auto mb-1" %>
          <p class="text-foreground font-medium">无销售骚扰</p>
