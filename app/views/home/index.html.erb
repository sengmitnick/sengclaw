<!-- CTA / Contact -->
<section id="contact" class="py-24 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <div class="w-20 h-20 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-6 text-4xl">🦐</div>
    <h2 class="text-4xl font-bold text-foreground mb-4">你的 AI 研发团队，随时待命</h2>
    <p class="text-lg text-secondary mb-10">随时在线，自主运转，像有一支研发团队在背后支撑你。</p>
    <div class="card p-8 text-left max-w-md mx-auto">
      <h3 class="text-lg font-semibold text-foreground mb-4 text-center">申请免费体验</h3>
      <div class="space-y-4">
        <div>
          <label class="form-label">你的名字</label>
          <input type="text" class="form-input" placeholder="张总">
        </div>
        <div>
          <label class="form-label">联系方式（微信 / 手机）</label>
          <input type="text" class="form-input" placeholder="微信号或手机号">
        </div>
        <div>
          <label class="form-label">你想用 AI 解决什么问题？</label>
          <textarea class="form-textarea" rows="3" placeholder="简单描述一下你的业务需求..."></textarea>
        </div>
        <button class="btn-primary w-full">
          <%= lucide_icon "send", class: "w-4 h-4" %>
          提交申请
        </button>
      </div>
      <p class="text-xs text-muted text-center mt-4">我们会在 24 小时内联系你 🦐</p>
    </div>
  </div>
</section>

<!-- Footer -->
