<div class="max-w-2xl mx-auto px-6 py-24">
  <div class="text-center mb-12">
    <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
      <%= image_tag "sengclaw-logo.png", class: "w-10 h-10 object-contain", alt: "大胜龙虾" %>
    </div>
    <h1 class="text-4xl font-bold text-foreground mb-4">联系我们</h1>
    <p class="text-lg text-secondary">扫码加微信，直接聊需求</p>
    <p class="text-sm text-muted mt-2">无论你是一人公司还是传统企业，先聊聊再说</p>
  </div>

  <!-- QR Code -->
  <div class="flex justify-center mb-8">
    <div class="rounded-xl overflow-hidden">
      <%= image_tag "contact-qrcode.png", class: "w-80 h-auto block", alt: "微信扫码联系" %>
    </div>
  </div>

  <!-- Info Cards -->
  <div class="grid grid-cols-3 gap-4 mb-8">
    <div class="card p-4 text-center">
      <%= lucide_icon "message-circle", class: "w-5 h-5 text-primary mx-auto mb-2" %>
      <p class="text-sm font-medium text-foreground">免费咨询</p>
      <p class="text-xs text-muted mt-1">先聊需求再说方案</p>
    </div>
    <div class="card p-4 text-center">
      <%= lucide_icon "clock", class: "w-5 h-5 text-primary mx-auto mb-2" %>
      <p class="text-sm font-medium text-foreground">快速响应</p>
      <p class="text-xs text-muted mt-1">工作时间内实时回复</p>
    </div>
    <div class="card p-4 text-center">
      <%= lucide_icon "shield-check", class: "w-5 h-5 text-primary mx-auto mb-2" %>
      <p class="text-sm font-medium text-foreground">无销售骚扰</p>
      <p class="text-xs text-muted mt-1">不合适不强推</p>
    </div>
  </div>

  <div class="text-center">
    <a href="/" class="btn-outline">← 返回首页</a>
  </div>
</div>
